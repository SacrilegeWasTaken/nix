diff --git a/helix-term/src/config.rs b/helix-term/src/config.rs
index bcba8d8..e461225 100644
--- a/helix-term/src/config.rs
+++ b/helix-term/src/config.rs
@@ -14,6 +14,44 @@ pub struct Config {
     pub theme: Option<String>,
     pub keys: HashMap<Mode, KeyTrie>,
     pub editor: helix_view::editor::Config,
+    pub layout_remap: HashMap<char, char>,
+}
+
+/// Keyboard layout translation table built from pairs of equal-length
+/// `from`/`into` strings, mapping characters typed on a national layout
+/// onto the characters keybindings are defined with:
+///
+/// ```toml
+/// [[layout-remap]]
+/// from = "йцукен"
+/// into = "qwerty"
+/// ```
+#[derive(Debug, Clone, PartialEq, Default)]
+pub struct LayoutRemap(pub HashMap<char, char>);
+
+impl<'de> Deserialize<'de> for LayoutRemap {
+    fn deserialize<D>(deserializer: D) -> Result<Self, D::Error>
+    where
+        D: serde::Deserializer<'de>,
+    {
+        #[derive(Deserialize)]
+        #[serde(deny_unknown_fields)]
+        struct Entry {
+            from: String,
+            into: String,
+        }
+        let entries = Vec::<Entry>::deserialize(deserializer)?;
+        let mut map = HashMap::new();
+        for entry in &entries {
+            if entry.from.chars().count() != entry.into.chars().count() {
+                return Err(serde::de::Error::custom(
+                    "layout-remap: `from` and `into` must contain the same number of characters",
+                ));
+            }
+            map.extend(entry.from.chars().zip(entry.into.chars()));
+        }
+        Ok(LayoutRemap(map))
+    }
 }
 
