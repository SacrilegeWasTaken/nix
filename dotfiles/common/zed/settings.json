{
  "minimum_contrast_for_highlights": 35.0,
  "agent_ui_font_size": 14.0,
  "buffer_font_weight": 450.0,
  "icon_theme": "Material Icon Theme",
  "base_keymap": "VSCode",
  "minimap": {
    "show": "never",
  },
  "colorize_brackets": false,
  "agent": {
    "always_allow_tool_actions": true,
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-3-7-sonnet",
    },
    "profiles": {
      "main": {
        "name": "Main",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
  },
  "show_edit_predictions": true,
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "dock": "right",
    "font_size": 12.5,
    "blinking": "on",
    "cursor_shape": "bar",
  },
  "features": {
    "edit_prediction_provider": "copilot",
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_size": 16,
  "buffer_font_size": 12.5,
  "theme": {
    "mode": "system",
    "light": "One Dark",
    "dark": "GitHub Dark Colorblind",
  },
  "languages": {
    "Rust": {
      "formatter": "language_server",
      "format_on_save": "on",
    },
    "TOML": {
      "format_on_save": "off",
    },
    "Nix": {
      "format_on_save": "off",
    },
    "Haskell": {
      "show_edit_predictions": false,
      "format_on_save": "off",
    },
    "Cabal": {
      "format_on_save": "off",
    },
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "rustfmt": {
          "extraArgs": ["+nightly"],
        },
        "checkOnSave": true,
        "check": {
          "command": "clippy",
        },
        "highlightInactiveCode": false,
      },
    },
  },
  "experimental.theme_overrides": {
    "renamed.background": "#FFFFFF20",
    "search.match_background": "#FFFFFF20",
    "ghost_element.background": "#00000010",
    "ghost_element.hover": "#00000099",
    "background.appearance": "transparent",
    "background": "#000000BC",
    "editor.background": "#00000010",
    "editor.gutter.background": "#00000010",
    "title_bar.background": "#000000CC",
    "toolbar.background": "#00000010",
    "terminal.background": "#00000000",
    "status_bar.background": "#000000CC",
    "tab.active_background": "#000000",
    "tab.inactive_background": "#00000000",
    "tab_bar.background": "#00000010",
    "panel.background": "#00000000",
    "border": "#00000000",
    "border.variant": "#00000000",
    "scrollbar.track.border": "#00000000",
    "scrollbar.track.background": "#00000000",
    "scrollbar.thumb.background": "#00000000",
    "scrollbar.thumb.border": "#FFFFFF90",
    "editor.active_line.background": "#00000000",
    "text": "#FFFFFFAA",
    "text.muted": "#FFFFFFEE",
  },
}
